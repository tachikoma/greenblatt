# 거래 수수료 비율
# 키움 한국 주식 수수료는 약 0.015%
COMMISSION_FEE_RATE=0.00015

# 세금 비율
# 양도소득세 등을 고려한 비율 (기본 0.2%)
TAX_RATE=0.002

# ----------------------------
# 키움 REST 실거래/모의 설정
# ----------------------------

# mock | real
KIWOOM_MODE=mock

# 키움 Open API 앱키 / 시크릿
KIWOOM_APPKEY=
KIWOOM_SECRETKEY=

# 계좌번호(선택)
KIWOOM_ACCOUNT_NO=

# 주문 API 확장 포인트
# 브로커/계좌 설정에 맞게 조정
KIWOOM_ORDER_ENDPOINT=/api/dostk/ordr
KIWOOM_ORDER_API_ID=kt10000
KIWOOM_ORDER_BUY_API_ID=kt10000
KIWOOM_ORDER_SELL_API_ID=kt10001

# 미체결 조회/취소 API 확장 포인트
KIWOOM_ORDER_STATUS_ENDPOINT=/api/dostk/acnt
KIWOOM_ORDER_STATUS_API_ID=kt00007
KIWOOM_ORDER_CANCEL_ENDPOINT=/api/dostk/ordr
KIWOOM_ORDER_MODIFY_API_ID=kt10002
KIWOOM_ORDER_CANCEL_API_ID=kt10003

# 호가 조회 API 확장 포인트 (최우선 매수/매도호가 조회)
KIWOOM_QUOTE_ENDPOINT=/api/dostk/mrkcond
KIWOOM_QUOTE_API_ID=ka10004
KIWOOM_QUOTE_MARKET_TYPE=0

# 종목정보 리스트(ka10099) API 확장 포인트
# - ka10099는 종목 리스트를 페이지 단위로 반환할 수 있어 cont-yn/next-key 연속조회 사용
KIWOOM_STOCK_LIST_ENDPOINT=/api/dostk/stkinfo
KIWOOM_STOCK_LIST_API_ID=ka10099

# ka10099 연속조회 최대 페이지 수 (기본 50)
KIWOOM_STOCK_LIST_MAX_PAGES=50

# 날짜 일관성 정책
# false(권장, 백테스트): 과거 날짜 요청 시 Kiwoom 현재 스냅샷을 사용하지 않고 pykrx fallback 우선
# true (실거래/당일 우선): 과거 날짜도 Kiwoom 현재 스냅샷으로 대체 허용
KIWOOM_ALLOW_DATE_PROXY=false

# 펀더멘털 데이터 소스 분리 스위치
# 값: auto | kiwoom | pykrx
# - LIVE_FUNDAMENTAL_SOURCE: 실거래 기본값(권장 kiwoom)
# - BACKTEST_FUNDAMENTAL_SOURCE: 백테스트 기본값(권장 pykrx)
# - FUNDAMENTAL_SOURCE: selector 공통 기본값(override가 없을 때만 사용)
LIVE_FUNDAMENTAL_SOURCE=pykrx
BACKTEST_FUNDAMENTAL_SOURCE=pykrx
FUNDAMENTAL_SOURCE=auto

# Kiwoom 종목별 펀더멘털 병렬 조회 옵션
# KIWOOM_FUND_MAX=0 -> 전체 조회, 양수면 상위 N개 티커만 조회
KIWOOM_FUND_MAX=0
KIWOOM_FUND_CONCURRENCY=3

# 1차 프리필터(유동성/시총)로 종목별 조회 대상 축소
KIWOOM_PREFILTER_ENABLED=false
KIWOOM_PREFILTER_TARGET=500
KIWOOM_PREFILTER_MIN_MCAP=50000000000
KIWOOM_PREFILTER_MIN_TRADING_VALUE=0

# 펀더멘털(종목기본정보) API (ka10001)
# - ka10001은 종목별 펀더멘털/기본정보용 API이며 기본 엔드포인트가 /api/dostk/stkinfo 입니다.
# - KIWOOM_FUND_ENDPOINT: 펀더멘털 조회 URI (기본 /api/dostk/stkinfo)
# - KIWOOM_FUND_API_ID: 엔드포인트에 사용할 API ID (기본 ka10001)
KIWOOM_FUND_ENDPOINT=/api/dostk/stkinfo
KIWOOM_FUND_API_ID=ka10001

# 실행 파라미터 (통합 변수 사용 권장)
# 권장: 통합 변수명을 사용하세요 (예: `INVESTMENT_RATIO`, `NUM_STOCKS` 등).
# 호환성: 기존 `LIVE_`/`BACKTEST_` 접두어 변수가 남아있어도 작동합니다.

# 투자/선정 관련
INVESTMENT_RATIO=0.95    # (legacy: LIVE_INVESTMENT_RATIO / BACKTEST_INVESTMENT_RATIO)
NUM_STOCKS=40            # (legacy: LIVE_NUM_STOCKS / BACKTEST_NUM_STOCKS)
REBALANCE_MONTHS=3       # (legacy: LIVE_REBALANCE_MONTHS / BACKTEST_REBALANCE_MONTHS)
STRATEGY_MODE=mixed      # (legacy: LIVE_STRATEGY_MODE / BACKTEST_STRATEGY_MODE)
MIXED_FILTER_PROFILE=large_cap  # (legacy: LIVE_MIXED_FILTER_PROFILE / BACKTEST_MIX_PROFILE)

# 모멘텀 관련
MOMENTUM_ENABLED=true    # (legacy: LIVE_MOMENTUM_ENABLED / BACKTEST_MOMENTUM_ENABLED)
MOMENTUM_MONTHS=3        # (legacy: LIVE_MOMENTUM_MONTHS / BACKTEST_MOMENTUM_MONTHS)
MOMENTUM_WEIGHT=0.60     # (legacy: LIVE_MOMENTUM_WEIGHT / BACKTEST_MOMENTUM_WEIGHT)
MOMENTUM_FILTER_ENABLED=true  # (legacy: LIVE_MOMENTUM_FILTER_ENABLED / BACKTEST_MOMENTUM_FILTER_ENABLED)
LARGE_CAP_MIN_MCAP=

# 비용/세금: 상단의 COMMISSION_FEE_RATE / TAX_RATE 사용 권장 (legacy: LIVE_COMMISSION_FEE_RATE / BACKTEST_COMMISSION_FEE_RATE)

# 기존 보유 종목 처리
EXISTING_POSITIONS_POLICY=sell  # hold | sell (legacy: LIVE_EXISTING_POSITIONS_POLICY)

# 주문/오류/재시도 관련
ORDER_TIMEOUT_MINUTES=3
ORDER_PRICE_OFFSET_BPS=10
USE_HOGA_RETRY_PRICE=true
LOG_QUOTE_RESPONSE=false
RETRY_PRICE_OFFSET_BPS=25
RETRY_ORDER_TYPE=03
USE_API_TICK=false
MAX_RETRY_ROUNDS=5
REBALANCE_GUARD_ENABLED=true
RUN_STATE_PATH=results/live_state/rebalance_state.json
RUN_LOCK_PATH=results/live_state/rebalance.lock
FALLBACK_TO_MARKET_CODES=4027
IGNORABLE_RETURN_CODES=4033

# 계좌 조회 API 확장 포인트 (변경 없음)
KIWOOM_BALANCE_ENDPOINT=/api/dostk/acnt
KIWOOM_BALANCE_API_ID=kt00018
KIWOOM_DEPOSIT_API_ID=kt00001

# 일일 체결 리포트 저장
SAVE_DAILY_REPORT=true     # (legacy: LIVE_SAVE_DAILY_REPORT)
REPORT_DIR=results/live_reports # (legacy: LIVE_REPORT_DIR)

# ----------------------------
# 변동성 타게팅 / 운영 옵션 (통합 변수)
# ----------------------------
# 포트폴리오 실현 변동성이 sigma 목표를 초과하면 투자 비율을 자동 축소
VOL_TARGET_ENABLED=false        # (legacy: LIVE_VOL_TARGET_ENABLED / BACKTEST_VOL_TARGET_ENABLED)
VOL_TARGET_SIGMA=0.20           # (legacy: LIVE_VOL_TARGET_SIGMA / BACKTEST_VOL_TARGET_SIGMA)
VOL_TARGET_LOOKBACK=20          # (legacy: LIVE_VOL_TARGET_LOOKBACK / BACKTEST_VOL_TARGET_LOOKBACK)
VOL_TARGET_MIN_RATIO=0.30       # (legacy: LIVE_VOL_TARGET_MIN_RATIO / BACKTEST_VOL_TARGET_MIN_RATIO)

# 개장 직후 실행 옵션
OPEN_WAIT_ENABLED=true          # (legacy: LIVE_OPEN_WAIT_ENABLED)
MARKET_OPEN_HHMM=09:00          # (legacy: LIVE_MARKET_OPEN_HHMM)
MARKET_OPEN_GRACE_SECONDS=30    # (legacy: LIVE_MARKET_OPEN_GRACE_SECONDS)

# 디버그/테스트용 추가 플래그
DEBUG_SIGNAL_ENABLED=false      # (legacy: LIVE_DEBUG_SIGNAL_ENABLED)
DEBUG_MAX_ROWS=50               # (legacy: LIVE_DEBUG_MAX_ROWS)

# 자본 제약 기반 종목 수 자동 선택
CAPITAL_CONSTRAINED_SELECTION_ENABLED=true
CAPITAL_CONSTRAINED_MIN_STOCKS=20
CAPITAL_CONSTRAINED_MAX_STOCKS=40

# 주문 제출/체결 감시 세부 파라미터
ORDER_SUBMIT_DELAY_SECONDS=0.1
ORDER_FILL_POLL_INTERVAL=0.5
ORDER_FILL_TIMEOUT_SECONDS=60.0
ORDER_FILL_MAX_AMEND=2
ORDER_FILL_AMEND_STRATEGY=reduce_price
ORDER_FILL_INITIAL_WAIT_SECONDS=5.0
ORDER_WATCH_START_RETRIES=3
ORDER_WATCH_START_BACKOFF_SECONDS=0.5

# ----------------------------
# 백테스트 파라미터
# ----------------------------

# 백테스트 기간 (YYYY-MM-DD 형식)
BACKTEST_START_DATE=2017-01-01
BACKTEST_END_DATE=2025-12-31

# 백테스트 초기 자본 (원)
BACKTEST_INITIAL_CAPITAL=5000000

# ----------------------------
# 변동성 타게팅 (백테스트)
# ----------------------------
# 포트폴리오 실현 변동성이 sigma 목표를 초과하면 투자 비율을 자동 축소
BACKTEST_VOL_TARGET_ENABLED=false
BACKTEST_VOL_TARGET_SIGMA=0.20
BACKTEST_VOL_TARGET_LOOKBACK=20
BACKTEST_VOL_TARGET_MIN_RATIO=0.30

# ----------------------------
# pykrx 세션 / KRX 로그인 (선택)
# ----------------------------
# PYKRX_SESSION_DEBUG: 디버그 출력 활성화 (1 또는 true)
# PYKRX_USER_AGENT: pykrx 요청에 사용할 User-Agent (선택)
# PYKRX_REFERER: pykrx 요청에 사용할 Referer (선택)
# PYKRX_LOGIN_ID: KRX 자동 로그인 아이디 (선택)
# PYKRX_LOGIN_PW: KRX 자동 로그인 비밀번호 (선택)

# 예시:
PYKRX_SESSION_DEBUG=0
PYKRX_USER_AGENT=Mozilla/5.0
PYKRX_REFERER=https://data.krx.co.kr/contents/MDC/MDI/outerLoader/index.cmd
PYKRX_LOGIN_ID=your_id
PYKRX_LOGIN_PW="your_password"
